# Copy to .env and fill in your values.

# Required once you have a cluster (Atlas or local).
MONGODB_URI=mongodb+srv://<username>:<password>@crud.g16123e.mongodb.net/?appName=crud

# Database and collection names
MONGODB_DATABASE=restapi
MONGODB_COLLECTION_MOVIES=movies

# Cover uploads (created on startup if missing)
UPLOAD_DIR=data/covers
# Max size per image in megabytes
MAX_UPLOAD_MB=10

# HTTP
HTTP_ADDR=:8080
